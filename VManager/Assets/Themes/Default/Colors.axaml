<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Tema Claro -->
    <SolidColorBrush x:Key="PanelBackgroundBrushLight">#fff5f0</SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrushPrimaryLight">#FFAAAAAA</SolidColorBrush>
    <SolidColorBrush x:Key="WindowBackgroundBrushLight">#fff7f3</SolidColorBrush>
    <SolidColorBrush x:Key="ToggleButtonBorderLight">#1c1c1c</SolidColorBrush>

    <!-- Tema Oscuro -->
    <SolidColorBrush x:Key="PanelBackgroundBrushDark">#FF2A2A2A</SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrushPrimaryDark">#FF444444</SolidColorBrush>
    <SolidColorBrush x:Key="WindowBackgroundBrushDark">#1c1c1c</SolidColorBrush>
    <SolidColorBrush x:Key="ToggleButtonBorderDark">#fff7f3</SolidColorBrush>
        
    <!-- Forma de RangeSlider -->
    <CornerRadius x:Key="SliderThumbCornerRadius">0</CornerRadius>
    <x:Double x:Key="SliderHorizontalThumbWidth">10</x:Double>
    <x:Double x:Key="SliderHorizontalThumbHeight">20</x:Double>
        
    <!-- Fill fuera del slider -->
    <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="Gray"/>
    <SolidColorBrush x:Key="SliderTrackFillPressed" Color="Gray"/>

</ResourceDictionary>