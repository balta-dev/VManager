<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        x:Class="Updater.UpdateWindow"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="400"
        MinWidth="200" MinHeight="50"
        Background="{DynamicResource PanelBackgroundBrush}">
    <!-- Scroll principal -->
    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Visible">
        <StackPanel Spacing="15">
            <TextBlock x:Name="AwaitUpdate" Text="" HorizontalAlignment="Center" TextWrapping="Wrap"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="WhiteSmoke"/>
            
            <!-- Texto de versión -->
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center" TextWrapping="Wrap"
                       FontSize="23"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"/>
            
            <!-- Botón de descargar -->
            <Button x:Name="DownloadButton" Classes="Accented" IsVisible="False"
                    Content=""
                    Height="35"
                    Padding="20,5"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{DynamicResource AccentBrush}"
                    FontSize="15"
                    CornerRadius="6"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                <ProgressBar x:Name="ProgressBar" IsVisible="False" Height="5"></ProgressBar>
                <TextBlock x:Name="ProgressText" IsVisible="False" VerticalAlignment="Center" Text="" FontSize="15"/>
            </StackPanel>
            
                <!-- Release notes -->
            <TextBlock x:Name="ReleaseNotesText"
                       Opacity="0.85"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>